{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/loading", "destination": "/loading.html" },
    { "source": "/", "destination": "/Home.dc.html" },
    { "source": "/quem-somos", "destination": "/Quem-Somos.dc.html" },
    { "source": "/estrategia", "destination": "/Estrategia.dc.html" },
    { "source": "/pessoas", "destination": "/Pessoas.dc.html" },
    { "source": "/clientes", "destination": "/Clientes.dc.html" },
    { "source": "/ambiente", "destination": "/Ambiente.dc.html" },
    { "source": "/sobre", "destination": "/Sobre.dc.html" }
  ],
  "redirects": [
    { "source": "/Home.dc.html", "destination": "/", "permanent": true },
    { "source": "/Quem-Somos.dc.html", "destination": "/quem-somos", "permanent": true },
    { "source": "/Estrategia.dc.html", "destination": "/estrategia", "permanent": true },
    { "source": "/Pessoas.dc.html", "destination": "/pessoas", "permanent": true },
    { "source": "/Clientes.dc.html", "destination": "/clientes", "permanent": true },
    { "source": "/Ambiente.dc.html", "destination": "/ambiente", "permanent": true },
    { "source": "/Sobre.dc.html", "destination": "/sobre", "permanent": true }
  ]
}
